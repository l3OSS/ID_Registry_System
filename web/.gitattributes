# Normalize line endings — เก็บใน repo เป็น LF, checkout บน Windows เป็น CRLF
# (ดับ warning "LF will be replaced by CRLF" เวลา git add บน Windows)
* text=auto

# ไฟล์ไบนารี — ห้าม git ยุ่งกับ line ending
*.jpg   binary
*.jpeg  binary
*.png   binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.exe   binary
*.dll   binary
