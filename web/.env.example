# ===== ตัวอย่างไฟล์ตั้งค่า (.env.example) =====
# คัดลอกเป็น .env แล้วแก้ค่าจริง (หรือปล่อยให้ตัวติดตั้ง install/ สร้างให้อัตโนมัติ)
# ห้าม commit .env จริง — มี ENCRYPTION_KEY + รหัส DB (ถูก .gitignore ไว้แล้ว)

# ===== ฐานข้อมูล (MariaDB, utf8mb4) =====
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="reg"
DB_USER="root"
DB_PASS=""

# ===== ความปลอดภัย =====
# ENCRYPTION_KEY: ตัวติดตั้งสุ่มให้ (base64 ของ 32 bytes) — ห้ามใช้ค่าตัวอย่าง/ค่าว่างใน production
#   ถ้าว่าง ระบบจะ throw (P1/S6) แทนการเก็บ plaintext เงียบ ๆ
ENCRYPTION_KEY=""
# ENCRYPTION_METHOD: ข้อมูลเชิงอ้างอิงเท่านั้น — encrypt ใหม่ใช้ AES-256-GCM (prefix g1:) เสมอ,
#   decrypt อ่านได้ทั้ง GCM ใหม่และ CBC เก่าโดยดูจาก prefix (P6)
ENCRYPTION_METHOD="AES-256-GCM"

# ===== สภาพแวดล้อมแอป =====
# prod = ปิด display_errors (log อย่างเดียว) · ไม่ตั้งค่า/dev = แสดง error (P3/S7)
APP_ENV="dev"
